@page "/"
@model IndexModel
@{
    ViewData["Title"] = "Home";
    ViewData["Nav"] = "";
}

<!-- ============ HERO ============ -->
<section class="hero" aria-labelledby="titolo-hero" style="padding-top:3rem;">
    <svg class="quack" viewBox="0 0 200 140" aria-hidden="true">
        <polygon points="100,4 118,32 152,14 148,48 190,44 162,72 196,92 156,98 168,132 132,112 118,138 100,110 76,136 70,102 30,116 48,84 6,74 44,58 24,26 64,38 74,6 90,34"
                 fill="#F2B705" stroke="#17120E" stroke-width="4" stroke-linejoin="round"/>
        <text x="100" y="82" text-anchor="middle" font-family="Bangers, cursive" font-size="40" fill="#E23A2E" stroke="#17120E" stroke-width="1.2" transform="rotate(-6 100 76)">QUACK!</text>
    </svg>

    <div class="wrap hero-grid">
        <div>
            <h1 class="display hero-titolo" id="titolo-hero">Il Comune<br />ti risponde!</h1>
            <p class="hero-sub">Tributi, anagrafe, rifiuti, scuola: chiedi all'assistente virtuale e ricevi risposte tratte solo dalle fonti ufficiali del Comune.</p>
        </div>
        <div class="balloon-hero">
            <p class="balloon-chi">Assistente virtuale del Comune</p>
            <p class="frase">Ciao! Sono l'assistente di Paperopoli. Cosa vuoi sapere?</p>
            <form action="/assistente" method="get">
                <label class="visually-hidden" for="hero-domanda">Fai una domanda all'assistente virtuale</label>
                <input type="text" id="hero-domanda" name="q" autocomplete="off"
                       placeholder="Es. Quando scade la prima rata della TARI?" />
                <button type="submit" class="btn-fumetto">Chiedi!</button>
            </form>
        </div>
    </div>
</section>

<!-- ============ ARGOMENTI ============ -->
<section class="wrap" aria-labelledby="titolo-argomenti" style="padding-bottom:0;">
    <h2 class="visually-hidden" id="titolo-argomenti">Argomenti in evidenza</h2>
    <div class="argomenti">
        <a class="argomento" href="/servizi">Tributi</a>
        <a class="argomento" href="/servizi">Rifiuti e ambiente</a>
        <a class="argomento" href="/servizi">Scuola</a>
        <a class="argomento" href="/servizi">Documenti e anagrafe</a>
        <a class="argomento" href="/servizi">Pagamenti</a>
    </div>
</section>

<!-- ============ SERVIZI IN EVIDENZA ============ -->
<section class="wrap" aria-labelledby="titolo-servizi">
    <span class="sezione-eyebrow">Servizi</span>
    <h2 class="display sezione-titolo" id="titolo-servizi">Servizi in evidenza</h2>
    <div class="card-grid">
        <a class="card-fumetto" href="/servizi/tari">
            <span class="icona oro" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none" stroke="#17120E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 10 h18 l-2 16 h-14 Z" fill="#fff"/>
                    <path d="M5 10 h22 M12 10 v-3 h8 v3 M13 15 v7 M19 15 v7"/>
                </svg>
            </span>
            <h3>TARI e tributi</h3>
            <p>Scadenze, rate, tariffe e riduzioni della tassa sui rifiuti.</p>
        </a>
        <a class="card-fumetto" href="/servizi">
            <span class="icona acqua" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none" stroke="#17120E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 5 l5 8" />
                    <path d="M25 12 l1 9 -6 -1" />
                    <path d="M8 24 l-2 -8 6 0" />
                    <path d="M10 27 h12" />
                </svg>
            </span>
            <h3>Raccolta differenziata</h3>
            <p>Calendario del porta a porta e regole per ogni materiale.</p>
        </a>
        <a class="card-fumetto" href="/servizi">
            <span class="icona rossa" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none" stroke="#17120E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="8" width="24" height="16" rx="2" fill="#fff"/>
                    <circle cx="11" cy="15" r="3"/>
                    <path d="M7 21 q4 -3 8 0 M18 13 h7 M18 17 h7"/>
                </svg>
            </span>
            <h3>Anagrafe e carta d'identità</h3>
            <p>CIE, certificati, cambi di residenza e appuntamenti.</p>
        </a>
        <a class="card-fumetto" href="/servizi">
            <span class="icona oro" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none" stroke="#17120E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 15 L16 5 l11 10" />
                    <path d="M8 14 v12 h16 v-12" fill="#fff"/>
                    <circle cx="16" cy="20" r="4" fill="#FFD84D"/>
                    <path d="M16 18 v4 M14.5 19 h3"/>
                </svg>
            </span>
            <h3>IMU</h3>
            <p>Aliquote, acconto e saldo, esenzione abitazione principale.</p>
        </a>
        <a class="card-fumetto" href="/servizi">
            <span class="icona acqua" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none" stroke="#17120E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="7" width="24" height="15" rx="3" fill="#fff"/>
                    <path d="M4 15 h24 M8 22 v3 M24 22 v3"/>
                    <circle cx="9" cy="19" r="1" fill="#17120E"/>
                    <circle cx="23" cy="19" r="1" fill="#17120E"/>
                </svg>
            </span>
            <h3>Mensa e trasporto scolastico</h3>
            <p>Iscrizioni, tariffe per fascia ISEE e linee dello scuolabus.</p>
        </a>
        <a class="card-fumetto" href="/servizi">
            <span class="icona rossa" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none" stroke="#17120E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 4 h16 v24 l-3 -2 -3 2 -2 -2 -3 2 -2 -2 -3 2 Z" fill="#fff"/>
                    <path d="M12 10 h8 M12 14 h8 M12 18 h5"/>
                </svg>
            </span>
            <h3>Pagamenti e pagoPA</h3>
            <p>Avvisi, IUV e tutti i canali per pagare il Comune.</p>
        </a>
        <a class="card-fumetto" href="/amministrazione">
            <span class="icona oro" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none" stroke="#17120E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="16" cy="16" r="11" fill="#fff"/>
                    <path d="M16 9 v7 l5 3"/>
                </svg>
            </span>
            <h3>Uffici e orari</h3>
            <p>Dove siamo, quando riceviamo e come prendere appuntamento.</p>
        </a>
    </div>
</section>

<!-- ============ NOVITÀ ============ -->
<section class="wrap" aria-labelledby="titolo-novita">
    <span class="sezione-eyebrow">Novità</span>
    <h2 class="display sezione-titolo" id="titolo-novita">Ultime dal Comune</h2>
    <div class="card-grid">
        <a class="card-fumetto" href="/novita">
            <span class="card-data">Avviso · 1 luglio 2026</span>
            <h3>Porta a porta: nuovo calendario nel quartiere Dogburg</h3>
            <p>Dal 15 luglio cambia il giorno di raccolta di carta e cartone.</p>
        </a>
        <a class="card-fumetto" href="/novita">
            <span class="card-data">Notizia · 24 giugno 2026</span>
            <h3>Festa di San Quaquaraqua: variazioni degli orari</h3>
            <p>Gli sportelli comunali resteranno chiusi nella giornata del patrono.</p>
        </a>
        <a class="card-fumetto" href="/novita">
            <span class="card-data">Comunicato · 18 giugno 2026</span>
            <h3>Mensa scolastica: aperte le iscrizioni per il nuovo anno</h3>
            <p>Domande online entro il 31 agosto, tariffe per fascia ISEE.</p>
        </a>
    </div>
</section>

<!-- ============ BANNER ASSISTENTE ============ -->
<section class="wrap" aria-labelledby="titolo-banner-assistente">
    <div class="balloon-hero" style="max-width:760px; margin:0 auto;">
        <p class="balloon-chi">Assistente virtuale</p>
        <h2 class="display" id="titolo-banner-assistente" style="font-size:1.8rem; margin-bottom:.4rem;">Non trovi quello che cerchi?</h2>
        <p class="frase">Chiedi all'assistente: risponde solo con le fonti certificate del Comune e cita sempre il passaggio ufficiale, ad esempio <span class="fonte-chip">tari:p02</span></p>
        <a class="btn-fumetto" href="/assistente">Apri l'assistente</a>
    </div>
</section>
